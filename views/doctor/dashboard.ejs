<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="portal-container">
  <!-- Sidebar -->
  <aside class="portal-sidebar">
    <div class="text-center mb-4 pb-3 border-bottom">
      <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center font-weight-bold mx-auto mb-2 display-font" style="width: 60px; height: 60px; font-size: 1.5rem;">
        Dr.
      </div>
      <h6 class="mb-0 text-dark font-weight-bold"><%= doctor.name %></h6>
      <small class="text-muted"><%= doctor.specialization %></small>
    </div>
    
    <ul class="sidebar-nav">
      <li class="sidebar-nav-item">
        <a href="/doctor/dashboard" class="sidebar-nav-link active">
          <i class="fa-solid fa-house-medical"></i> Queue Dashboard
        </a>
      </li>
      <li class="sidebar-nav-item">
        <a href="/doctor/schedule" class="sidebar-nav-link">
          <i class="fa-solid fa-clock"></i> Schedule Planner
        </a>
      </li>
      <li class="sidebar-nav-item">
        <a href="/doctor/history" class="sidebar-nav-link">
          <i class="fa-solid fa-file-medical"></i> Consultation History
        </a>
      </li>
    </ul>
  </aside>

  <!-- Content Area -->
  <main class="portal-content">
    <div class="container-fluid">
      
      <!-- Top header line -->
      <div class="row mb-4 align-items-center">
        <div class="col">
          <h2 class="display-font text-dark mb-1">Queue Control Panel</h2>
          <p class="text-muted mb-0">Manage your consultation list, call next tokens, prioritize emergencies, or pause for breaks.</p>
        </div>
        <div class="col-auto">
          <span class="d-flex align-items-center">
            <span class="<%= queueState.isPaused ? 'pulse-indicator-warning' : 'pulse-indicator' %> me-2" id="livePulse"></span>
            <small class="text-muted font-weight-bold" id="livePulseText">
              <%= queueState.isPaused ? 'Queue Paused (Break)' : 'Live Consultation Active' %>
            </small>
          </span>
        </div>
      </div>

      <% if (success) { %>
        <div class="alert alert-success alert-dismissible fade show border-0 p-3 mb-4" role="alert" style="border-radius: 12px; font-weight: 500;">
          <i class="fa-solid fa-circle-check me-2"></i> <%= success %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% } %>

      <!-- Count Widgets -->
      <div class="row g-4 mb-4">
        <div class="col-6 col-lg-3">
          <div class="med-card d-flex align-items-center border-start border-primary border-4 p-3">
            <div class="med-card-icon mb-0 me-3" style="width: 48px; height: 48px; border-radius: 12px;">
              <i class="fa-solid fa-users"></i>
            </div>
            <div>
              <h6 class="text-muted mb-1 small font-weight-bold">Today's Visits</h6>
              <h3 class="mb-0 text-dark font-weight-bold" id="statToday"><%= stats.totalToday %></h3>
            </div>
          </div>
        </div>
        <div class="col-6 col-lg-3">
          <div class="med-card d-flex align-items-center border-start border-warning border-4 p-3">
            <div class="med-card-icon bg-warning-light text-warning mb-0 me-3" style="width: 48px; height: 48px; border-radius: 12px;">
              <i class="fa-solid fa-hourglass-half"></i>
            </div>
            <div>
              <h6 class="text-muted mb-1 small font-weight-bold">Patients Waiting</h6>
              <h3 class="mb-0 text-dark font-weight-bold" id="statWaiting"><%= stats.waitingCount %></h3>
            </div>
          </div>
        </div>
        <div class="col-6 col-lg-3">
          <div class="med-card d-flex align-items-center border-start border-success border-4 p-3">
            <div class="med-card-icon bg-success-light text-success mb-0 me-3" style="width: 48px; height: 48px; border-radius: 12px;">
              <i class="fa-solid fa-user-check"></i>
            </div>
            <div>
              <h6 class="text-muted mb-1 small font-weight-bold">Completed</h6>
              <h3 class="mb-0 text-dark font-weight-bold" id="statCompleted"><%= stats.completedCount %></h3>
            </div>
          </div>
        </div>
        <div class="col-6 col-lg-3">
          <div class="med-card d-flex align-items-center border-start border-secondary border-4 p-3">
            <div class="med-card-icon bg-light text-secondary mb-0 me-3" style="width: 48px; height: 48px; border-radius: 12px;">
              <i class="fa-solid fa-forward"></i>
            </div>
            <div>
              <h6 class="text-muted mb-1 small font-weight-bold">Skipped/Absent</h6>
              <h3 class="mb-0 text-dark font-weight-bold" id="statSkipped"><%= stats.skippedCount %></h3>
            </div>
          </div>
        </div>
      </div>

      <!-- Core Queue Operations & Panel Grid -->
      <div class="row g-4">
        <!-- Call Controllers & Current Patient -->
        <div class="col-lg-5">
          
          <!-- Current Patient Panel -->
          <div class="med-card mb-4 border-2 border-primary" style="background: linear-gradient(185deg, #ffffff 0%, #f0f7ff 100%);">
            <h5 class="text-primary font-weight-bold display-font mb-3"><i class="fa-solid fa-stethoscope me-2"></i> Current Patient</h5>
            
            <div id="currentPatientCard">
              <% if (currentPatient) { %>
                <div class="text-center py-2">
                  <span class="badge bg-primary text-white py-2 px-3 rounded-pill display-font fs-6 mb-3">Token T-<%= currentPatient.tokenNumber.toString().padStart(2, '0') %></span>
                  <h4 class="text-dark font-weight-bold mb-1"><%= currentPatient.patientName %></h4>
                  <p class="text-muted mb-3"><%= currentPatient.patientAge %> Yrs • <%= currentPatient.patientGender %></p>
                  
                  <div class="bg-white p-3 rounded-3 text-start border shadow-sm mb-4">
                    <small class="text-muted font-weight-bold text-uppercase d-block mb-1">Chief Symptoms</small>
                    <span class="text-dark"><%= currentPatient.symptoms || 'General routine consultation' %></span>
                  </div>

                  <div class="d-flex gap-2">
                    <form action="/doctor/queue/complete" method="POST" class="flex-grow-1">
                      <button type="submit" class="btn btn-success w-100 py-3 rounded-3" style="font-weight: 700;">
                        <i class="fa-solid fa-check-circle me-1"></i> Complete Consult
                      </button>
                    </form>
                    
                    <form action="/doctor/queue/skip" method="POST" class="flex-grow-1">
                      <button type="submit" class="btn btn-outline-secondary w-100 py-3 rounded-3" style="font-weight: 700;">
                        <i class="fa-solid fa-forward me-1"></i> Skip Patient
                      </button>
                    </form>
                  </div>
                </div>
              <% } else { %>
                <div class="text-center py-5 text-muted">
                  <i class="fa-solid fa-clipboard-user fs-1 mb-3 d-block text-primary-subtle"></i>
                  <h5 class="text-dark font-weight-bold mb-1">No Active Patient</h5>
                  <p class="small mb-0">Click "Call Next" to start consulting the next patient in queue.</p>
                </div>
              <% } %>
            </div>
          </div>

          <!-- Queue Control Hub -->
          <div class="med-card p-4">
            <h5 class="text-dark font-weight-bold mb-3 border-bottom pb-2">Control Panel</h5>
            
            <div class="d-grid gap-3">
              <form action="/doctor/queue/call-next" method="POST">
                <button type="submit" class="btn btn-med-primary w-100 py-3 d-flex align-items-center justify-content-center" id="callNextBtn" <%= queueState.activeQueue.length === 0 ? 'disabled' : '' %>>
                  <i class="fa-solid fa-volume-high me-2"></i> Call Next Patient
                </button>
              </form>

              <form action="/doctor/queue/toggle-break" method="POST">
                <button type="submit" class="btn btn-outline-warning w-100 py-3 d-flex align-items-center justify-content-center border-2" style="border-radius: 12px; font-weight: 700;" id="breakBtn">
                  <% if (queueState.isPaused) { %>
                    <i class="fa-solid fa-play me-2"></i> Resume Consultation Queue
                  <% } else { %>
                    <i class="fa-solid fa-pause me-2"></i> Schedule Break (Pause Queue)
                  <% } %>
                </button>
              </form>
            </div>
          </div>

        </div>

        <!-- Waiting Queue List -->
        <div class="col-lg-7">
          <div class="med-card h-100">
            <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
              <h4 class="text-dark font-weight-bold display-font mb-0"><i class="fa-solid fa-users-line text-primary me-2"></i> Patient Waiting List</h4>
              <span class="badge bg-warning-light text-warning" id="queueBadgeCount"><%= activeQueue.length %> In Queue</span>
            </div>

            <div id="waitingListContainer">
              <% if (activeQueue.length === 0) { %>
                <div class="text-center py-5 text-muted">
                  <i class="fa-solid fa-folder-open fs-2 mb-2 d-block text-muted-subtle"></i>
                  No patients waiting in queue today.
                </div>
              <% } else { %>
                <div class="d-grid gap-3" id="waitingCards">
                  <% activeQueue.forEach((patient, idx) => { %>
                    <div class="border rounded-4 p-3 bg-light shadow-sm position-relative d-flex justify-content-between align-items-center">
                      <div class="d-flex align-items-start">
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center font-weight-bold me-3 font-display" style="width: 44px; height: 44px; flex-shrink: 0;">
                          <%= patient.tokenNumber %>
                        </div>
                        <div>
                          <h6 class="text-dark font-weight-bold mb-1"><%= patient.patientName %></h6>
                          <small class="text-muted d-block small mb-1">Age: <%= patient.patientAge %> • Slot: <%= patient.timeSlot %></small>
                          <small class="text-muted d-block small"><strong>Symptoms:</strong> <%= patient.symptoms || 'Routine review' %></small>
                        </div>
                      </div>
                      <div class="text-end">
                        <span class="badge bg-white text-muted border mb-2 d-block small">Pos #<%= idx + 1 %></span>
                        <% if (!patient.isEmergency) { %>
                          <form action="/doctor/queue/emergency" method="POST">
                            <input type="hidden" name="appointmentId" value="<%= patient._id %>">
                            <button type="submit" class="btn btn-outline-danger btn-sm border-2 font-weight-bold" style="border-radius: 8px;">
                              <i class="fa-solid fa-circle-exclamation me-1"></i> Priority
                            </button>
                          </form>
                        <% } else { %>
                          <span class="med-badge med-badge-emergency"><i class="fa-solid fa-circle-exclamation"></i> Emergency</span>
                        <% } %>
                      </div>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            </div>

          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<!-- Socket.IO dynamic synchronization for Doctor view -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const socket = io();
    const doctorId = '<%= user.id %>';

    // Join doctor's own queue room
    socket.emit('joinQueue', { doctorId });

    socket.on('queueUpdated', (data) => {
      // Data contains: isPaused, currentPatient, activeQueue, slotDuration
      
      // 1. Update pulse indicators
      const livePulse = document.getElementById('livePulse');
      const livePulseText = document.getElementById('livePulseText');
      const breakBtn = document.getElementById('breakBtn');

      if (data.isPaused) {
        livePulse.className = 'pulse-indicator-warning me-2';
        livePulseText.textContent = 'Queue Paused (Break)';
        breakBtn.innerHTML = '<i class="fa-solid fa-play me-2"></i> Resume Consultation Queue';
      } else {
        livePulse.className = 'pulse-indicator me-2';
        livePulseText.textContent = 'Live Consultation Active';
        breakBtn.innerHTML = '<i class="fa-solid fa-pause me-2"></i> Schedule Break (Pause Queue)';
      }

      // 2. Update Stats Counter
      document.getElementById('statWaiting').textContent = data.activeQueue.length;
      document.getElementById('queueBadgeCount').textContent = data.activeQueue.length + ' In Queue';
      
      // Enable/disable call next button
      const callNextBtn = document.getElementById('callNextBtn');
      callNextBtn.disabled = data.activeQueue.length === 0;

      // 3. Redraw Current Patient Panel
      const currentPatientCard = document.getElementById('currentPatientCard');
      if (data.currentPatient) {
        const tokenNum = String(data.currentPatient.tokenNumber).padStart(2, '0');
        currentPatientCard.innerHTML = `
          <div class="text-center py-2">
            <span class="badge bg-primary text-white py-2 px-3 rounded-pill display-font fs-6 mb-3">Token T-${tokenNum}</span>
            <h4 class="text-dark font-weight-bold mb-1">${data.currentPatient.patientName}</h4>
            <p class="text-muted mb-3">${data.currentPatient.patientAge} Yrs</p>
            
            <div class="bg-white p-3 rounded-3 text-start border shadow-sm mb-4">
              <small class="text-muted font-weight-bold text-uppercase d-block mb-1">Chief Symptoms</small>
              <span class="text-dark">${data.currentPatient.symptoms || 'General routine consultation'}</span>
            </div>

            <div class="d-flex gap-2">
              <form action="/doctor/queue/complete" method="POST" class="flex-grow-1">
                <button type="submit" class="btn btn-success w-100 py-3 rounded-3" style="font-weight: 700;">
                  <i class="fa-solid fa-check-circle me-1"></i> Complete Consult
                </button>
              </form>
              
              <form action="/doctor/queue/skip" method="POST" class="flex-grow-1">
                <button type="submit" class="btn btn-outline-secondary w-100 py-3 rounded-3" style="font-weight: 700;">
                  <i class="fa-solid fa-forward me-1"></i> Skip Patient
                </button>
              </form>
            </div>
          </div>
        `;
      } else {
        currentPatientCard.innerHTML = `
          <div class="text-center py-5 text-muted">
            <i class="fa-solid fa-clipboard-user fs-1 mb-3 d-block text-primary-subtle"></i>
            <h5 class="text-dark font-weight-bold mb-1">No Active Patient</h5>
            <p class="small mb-0">Click "Call Next" to start consulting the next patient in queue.</p>
          </div>
        `;
      }

      // 4. Redraw Waiting list container
      const waitingListContainer = document.getElementById('waitingListContainer');
      if (data.activeQueue.length === 0) {
        waitingListContainer.innerHTML = `
          <div class="text-center py-5 text-muted">
            <i class="fa-solid fa-folder-open fs-2 mb-2 d-block text-muted-subtle"></i>
            No patients waiting in queue today.
          </div>
        `;
      } else {
        let cardsHtml = '<div class="d-grid gap-3" id="waitingCards">';
        data.activeQueue.forEach((patient, idx) => {
          const badgeHtml = patient.isEmergency 
            ? '<span class="med-badge med-badge-emergency"><i class="fa-solid fa-circle-exclamation"></i> Emergency</span>'
            : `<form action="/doctor/queue/emergency" method="POST">
                 <input type="hidden" name="appointmentId" value="${patient._id}">
                 <button type="submit" class="btn btn-outline-danger btn-sm border-2 font-weight-bold" style="border-radius: 8px;">
                   <i class="fa-solid fa-circle-exclamation me-1"></i> Priority
                 </button>
               </form>`;

          cardsHtml += `
            <div class="border rounded-4 p-3 bg-light shadow-sm position-relative d-flex justify-content-between align-items-center">
              <div class="d-flex align-items-start">
                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center font-weight-bold me-3 font-display" style="width: 44px; height: 44px; flex-shrink: 0;">
                  ${patient.tokenNumber}
                </div>
                <div>
                  <h6 class="text-dark font-weight-bold mb-1">${patient.patientName}</h6>
                  <small class="text-muted d-block small mb-1">Age: ${patient.patientAge} • Slot: ${patient.timeSlot}</small>
                  <small class="text-muted d-block small"><strong>Symptoms:</strong> ${patient.symptoms || 'Routine review'}</small>
                </div>
              </div>
              <div class="text-end">
                <span class="badge bg-white text-muted border mb-2 d-block small">Pos #${idx + 1}</span>
                ${badgeHtml}
              </div>
            </div>
          `;
        });
        cardsHtml += '</div>';
        waitingListContainer.innerHTML = cardsHtml;
      }
    });
  });
</script>

<%- include('../partials/footer') %>
