<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="portal-container">
  <!-- Sidebar -->
  <aside class="portal-sidebar">
    <div class="text-center mb-4 pb-3 border-bottom">
      <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center font-weight-bold mx-auto mb-2 display-font" style="width: 60px; height: 60px; font-size: 1.5rem;">
        <%= user.name.split(' ').map(n => n[0]).join('') %>
      </div>
      <h6 class="mb-0 text-dark font-weight-bold"><%= user.name %></h6>
      <small class="text-muted"><%= user.email %></small>
    </div>
    
    <ul class="sidebar-nav">
      <li class="sidebar-nav-item">
        <a href="/patient/dashboard" class="sidebar-nav-link active">
          <i class="fa-solid fa-gauge"></i> Dashboard
        </a>
      </li>
      <li class="sidebar-nav-item">
        <a href="/patient/book" class="sidebar-nav-link">
          <i class="fa-solid fa-calendar-plus"></i> Book Slot
        </a>
      </li>
      <li class="sidebar-nav-item">
        <a href="/patient/appointments" class="sidebar-nav-link">
          <i class="fa-solid fa-clock-history"></i> Appointments
        </a>
      </li>
    </ul>
  </aside>

  <!-- Main Dashboard Content -->
  <main class="portal-content">
    <div class="container-fluid">
      <div class="row mb-4 align-items-center">
        <div class="col">
          <h2 class="display-font text-dark mb-1">Welcome back, <%= user.name %>!</h2>
          <p class="text-muted mb-0">Track your queue positions and manage appointments from this portal.</p>
        </div>
      </div>
      
      <!-- Stats Cards -->
      <div class="row g-4 mb-4">
        <div class="col-md-4">
          <div class="med-card d-flex align-items-center border-start border-primary border-4 p-3">
            <div class="med-card-icon mb-0 me-3" style="width: 48px; height: 48px; border-radius: 12px;">
              <i class="fa-solid fa-calendar-check"></i>
            </div>
            <div>
              <h6 class="text-muted mb-1 small font-weight-bold">Total Bookings</h6>
              <h3 class="mb-0 text-dark font-weight-bold"><%= stats.totalBooked %></h3>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="med-card d-flex align-items-center border-start border-success border-4 p-3">
            <div class="med-card-icon bg-success-light text-success mb-0 me-3" style="width: 48px; height: 48px; border-radius: 12px;">
              <i class="fa-solid fa-circle-check"></i>
            </div>
            <div>
              <h6 class="text-muted mb-1 small font-weight-bold">Completed Visits</h6>
              <h3 class="mb-0 text-dark font-weight-bold"><%= stats.completedCount %></h3>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="med-card d-flex align-items-center border-start border-danger border-4 p-3">
            <div class="med-card-icon bg-danger-light text-danger mb-0 me-3" style="width: 48px; height: 48px; border-radius: 12px;">
              <i class="fa-solid fa-circle-xmark"></i>
            </div>
            <div>
              <h6 class="text-muted mb-1 small font-weight-bold">Cancelled bookings</h6>
              <h3 class="mb-0 text-dark font-weight-bold"><%= stats.cancelledCount %></h3>
            </div>
          </div>
        </div>
      </div>

      <!-- Main Section: Live Queue Tracker -->
      <div class="row g-4">
        <div class="col-lg-8">
          <% if (activeAppointment) { %>
            <div class="med-card mb-4">
              <div class="d-flex justify-content-between align-items-start border-bottom pb-3 mb-4">
                <div>
                  <h4 class="text-dark display-font mb-1">Today's Appointment Queue</h4>
                  <p class="text-muted mb-0 small">
                    Consulting with <strong><%= activeAppointment.doctorName %></strong> (<%= activeAppointment.specialization %>)
                  </p>
                </div>
                <% if (activeAppointment.isEmergency) { %>
                  <span class="med-badge med-badge-emergency"><i class="fa-solid fa-circle-exclamation me-1"></i> Emergency Priority</span>
                <% } else { %>
                  <span class="med-badge med-badge-approved"><i class="fa-solid fa-circle-check me-1"></i> Active Booking</span>
                <% } %>
              </div>

              <!-- Break Banner (Hidden by default, displayed via script) -->
              <div id="pauseBanner" class="alert alert-warning border-0 p-3 mb-4 d-none" style="border-radius: 12px;">
                <div class="d-flex">
                  <div class="me-3">
                    <span class="pulse-indicator-warning"></span>
                  </div>
                  <div>
                    <h6 class="alert-heading font-weight-bold text-warning-emphasis mb-1">Doctor is on a short break</h6>
                    <p class="mb-0 small text-warning-emphasis">The queue is currently paused. Average waiting times will adjust once consultation resumes.</p>
                  </div>
                </div>
              </div>

              <% if (queueInfo) { %>
                <div class="row g-4 text-center mb-4">
                  <div class="col-sm-4 border-end">
                    <div class="p-2">
                      <small class="text-muted font-weight-bold text-uppercase d-block mb-1">Current Token Called</small>
                      <h2 class="text-primary font-weight-bold display-font mb-0" id="currentTokenDisplay">
                        <%= queueInfo.currentToken %>
                      </h2>
                    </div>
                  </div>
                  
                  <div class="col-sm-4 border-end">
                    <div class="p-2">
                      <small class="text-muted font-weight-bold text-uppercase d-block mb-1">Your Token Number</small>
                      <h2 class="text-dark font-weight-bold display-font mb-0">
                        <%= queueInfo.yourToken %>
                      </h2>
                    </div>
                  </div>
                  
                  <div class="col-sm-4">
                    <div class="p-2">
                      <small class="text-muted font-weight-bold text-uppercase d-block mb-1">Live Queue Position</small>
                      <h2 class="text-success font-weight-bold display-font mb-0" id="positionDisplay">
                        <%= queueInfo.position %>
                      </h2>
                    </div>
                  </div>
                </div>

                <!-- Visual Progress Bar -->
                <div class="queue-tracker-container mb-4 px-3">
                  <div class="queue-progress-bar">
                    <div class="queue-progress-active" id="progressBarActive" style="width: <%= queueInfo.position === 'Current' ? '100%' : (queueInfo.position === 1 ? '50%' : '25%') %>;"></div>
                    
                    <div class="queue-step completed">
                      <div class="queue-step-icon"><i class="fa-solid fa-calendar-check"></i></div>
                      <div class="queue-step-label">Booked</div>
                    </div>
                    
                    <div class="queue-step <%= queueInfo.position !== 'Current' ? 'active' : 'completed' %>" id="step-queue">
                      <div class="queue-step-icon"><i class="fa-solid fa-list-ol"></i></div>
                      <div class="queue-step-label">In Queue</div>
                    </div>
                    
                    <div class="queue-step <%= queueInfo.position === 'Current' ? 'active' : '' %>" id="step-call">
                      <div class="queue-step-icon"><i class="fa-solid fa-stethoscope"></i></div>
                      <div class="queue-step-label">Called</div>
                    </div>
                  </div>
                </div>

                <div class="bg-light p-3 rounded-4 d-flex justify-content-between align-items-center">
                  <div class="d-flex align-items-center">
                    <i class="fa-solid fa-hourglass-half text-primary fs-5 me-3"></i>
                    <div>
                      <span class="text-muted small d-block">Estimated Waiting Time</span>
                      <strong class="text-dark font-weight-bold" id="waitTimeDisplay">
                        <%= queueInfo.estWaitingTime %> mins
                      </strong>
                    </div>
                  </div>
                  <div class="text-end text-muted small">
                    People ahead: <strong class="text-dark" id="peopleAheadDisplay"><%= queueInfo.peopleAhead %></strong>
                  </div>
                </div>
              <% } else { %>
                <!-- Appointment is today but doctor queue has not started -->
                <div class="text-center py-4">
                  <div class="med-card-icon bg-warning-light text-warning mx-auto mb-3" style="width: 48px; height: 48px; border-radius: 50%;">
                    <i class="fa-solid fa-clock"></i>
                  </div>
                  <h5 class="text-dark font-weight-bold">Queue Not Yet Active</h5>
                  <p class="text-muted small px-3">
                    Your appointment is booked for today at <strong><%= activeAppointment.timeSlot %></strong>. The doctor's queue will activate once the first consultation begins.
                  </p>
                </div>
              <% } %>
            </div>
          <% } else { %>
            <div class="med-card text-center py-5 mb-4">
              <div class="med-card-icon bg-primary-light text-primary mx-auto mb-3" style="width: 64px; height: 64px; border-radius: 50%;">
                <i class="fa-solid fa-calendar-check fs-4"></i>
              </div>
              <h4 class="text-dark display-font mb-2">No Active Appointments Today</h4>
              <p class="text-muted small mx-auto mb-4" style="max-width: 450px;">
                You do not have any pending appointments scheduled for today. Book a consulting slot to interact with our live tracking system.
              </p>
              <a href="/patient/book" class="btn btn-med-primary px-4">
                <i class="fa-solid fa-calendar-plus me-2"></i> Book A Consultation
              </a>
            </div>
          <% } %>
        </div>
        
        <!-- Sidebar Right Card: Quick Actions -->
        <div class="col-lg-4">
          <!-- Action Hub -->
          <div class="med-card mb-4 p-4">
            <h5 class="text-dark font-weight-bold mb-3 border-bottom pb-2">Quick Actions</h5>
            <div class="d-grid gap-3">
              <a href="/patient/book" class="btn btn-med-primary text-start px-3 py-3 d-flex align-items-center">
                <div class="bg-white text-primary rounded-3 d-flex align-items-center justify-content-center me-3" style="width: 36px; height: 36px;">
                  <i class="fa-solid fa-calendar-plus"></i>
                </div>
                <div>
                  <h6 class="mb-0 text-white font-weight-bold">Book Appointment</h6>
                  <small class="text-white-50">Select slots in 60s</small>
                </div>
              </a>
              
              <a href="/patient/appointments" class="btn btn-med-secondary text-start px-3 py-3 d-flex align-items-center">
                <div class="bg-primary-light text-primary rounded-3 d-flex align-items-center justify-content-center me-3" style="width: 36px; height: 36px;">
                  <i class="fa-solid fa-clock-history"></i>
                </div>
                <div>
                  <h6 class="mb-0 text-primary font-weight-bold">Appointment History</h6>
                  <small class="text-muted">Review previous visits</small>
                </div>
              </a>
            </div>
          </div>
          
          <!-- Next Appointment Card -->
          <% if (activeAppointment) { %>
            <div class="token-card p-4">
              <div class="token-badge"><i class="fa-solid fa-ticket me-1"></i> Digital Pass</div>
              <h5 class="text-white-50 mb-1 small text-uppercase font-weight-bold">Doctor Consultation Pass</h5>
              <h3 class="text-white font-weight-bold mb-3"><%= activeAppointment.doctorName %></h3>
              
              <div class="border-top border-white-10 pt-3 mb-3">
                <div class="row g-2 text-center text-sm-start">
                  <div class="col-6">
                    <small class="text-white-50 d-block small">TIME SLOT</small>
                    <strong class="text-white"><%= activeAppointment.timeSlot %></strong>
                  </div>
                  <div class="col-6">
                    <small class="text-white-50 d-block small">DATE</small>
                    <strong class="text-white"><%= activeAppointment.date %></strong>
                  </div>
                </div>
              </div>
              
              <div class="bg-white-10 p-3 rounded-3 mt-3 text-center border border-white-10">
                <small class="text-white-50 d-block mb-1 font-weight-bold text-uppercase">Token Number</small>
                <div class="token-number-display mb-0">
                  T-<%= activeAppointment.tokenNumber.toString().padStart(2, '0') %>
                </div>
              </div>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </main>
</div>

<!-- Socket.IO integration for live updates -->
<% if (activeAppointment && queueInfo) { %>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const socket = io();
      const doctorId = '<%= activeAppointment.doctor %>';
      const apptId = '<%= activeAppointment._id %>';
      
      // Join room for this doctor
      socket.emit('joinQueue', { doctorId });
      
      socket.on('queueUpdated', (data) => {
        const currentTokenSpan = document.getElementById('currentTokenDisplay');
        const positionSpan = document.getElementById('positionDisplay');
        const peopleAheadSpan = document.getElementById('peopleAheadDisplay');
        const waitTimeSpan = document.getElementById('waitTimeDisplay');
        const pauseBanner = document.getElementById('pauseBanner');
        const progressBar = document.getElementById('progressBarActive');
        const stepQueue = document.getElementById('step-queue');
        const stepCall = document.getElementById('step-call');

        // Toggle break warning banner
        if (data.isPaused) {
          pauseBanner.classList.remove('d-none');
        } else {
          pauseBanner.classList.add('d-none');
        }

        // 1. Update current token display
        if (data.currentPatient) {
          currentTokenSpan.textContent = 'T-' + String(data.currentPatient.tokenNumber).padStart(2, '0');
        } else {
          currentTokenSpan.textContent = 'None';
        }

        // 2. Recalculate positions
        if (data.currentPatient && data.currentPatient._id === apptId) {
          positionSpan.textContent = 'Current';
          peopleAheadSpan.textContent = '0';
          waitTimeSpan.textContent = '0 mins (You are being called!)';
          progressBar.style.width = '100%';
          stepQueue.classList.add('completed');
          stepCall.classList.add('active');
        } else {
          const idx = data.activeQueue.findIndex(x => x._id === apptId);
          if (idx !== -1) {
            const pos = idx + 1;
            positionSpan.textContent = pos;
            peopleAheadSpan.textContent = idx;
            waitTimeSpan.textContent = (idx * data.slotDuration) + ' mins';
            progressBar.style.width = pos === 1 ? '50%' : '25%';
            stepQueue.classList.add('active');
            stepQueue.classList.remove('completed');
            stepCall.classList.remove('active');
          } else {
            // Not in queue nor current called (could be complete or skipped)
            // Perform a reload to show history / update dashboard
            window.location.reload();
          }
        }
      });
    });
  </script>
<% } %>

<%- include('../partials/footer') %>
