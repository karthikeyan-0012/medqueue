<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="portal-container">
  <!-- Sidebar -->
  <aside class="portal-sidebar">
    <div class="text-center mb-4 pb-3 border-bottom">
      <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center font-weight-bold mx-auto mb-2 display-font" style="width: 60px; height: 60px; font-size: 1.5rem;">
        AD
      </div>
      <h6 class="mb-0 text-dark font-weight-bold">System Admin</h6>
      <small class="text-muted">Command Control</small>
    </div>
    
    <ul class="sidebar-nav">
      <li class="sidebar-nav-item">
        <a href="/admin/dashboard" class="sidebar-nav-link">
          <i class="fa-solid fa-chart-pie"></i> Metrics Overview
        </a>
      </li>
      <li class="sidebar-nav-item">
        <a href="/admin/doctors" class="sidebar-nav-link">
          <i class="fa-solid fa-user-md"></i> Doctor Directory
        </a>
      </li>
      <li class="sidebar-nav-item">
        <a href="/admin/patients" class="sidebar-nav-link active">
          <i class="fa-solid fa-hospital-user"></i> Patient Directory
        </a>
      </li>
    </ul>
  </aside>

  <!-- Content -->
  <main class="portal-content">
    <div class="container-fluid">
      
      <!-- Top header line -->
      <div class="row mb-4 align-items-center">
        <div class="col">
          <h2 class="display-font text-dark mb-1">Patient Directory</h2>
          <p class="text-muted mb-0">Inspect demographic profiles, manage account registrations, and audit patient appointment logs.</p>
        </div>
      </div>

      <% if (success) { %>
        <div class="alert alert-success alert-dismissible fade show border-0 p-3 mb-4" role="alert" style="border-radius: 12px; font-weight: 500;">
          <i class="fa-solid fa-circle-check me-2"></i> <%= success %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% } %>

      <!-- Patient Data Table -->
      <div class="med-card">
        <div class="mb-3 d-flex flex-wrap gap-2 justify-content-between align-items-center">
          <form action="/admin/patients" method="GET" class="d-flex w-100 w-md-350 gap-2">
            <input type="text" name="search" class="form-control form-med-control" placeholder="Search name, email, phone..." value="<%= search %>">
            <button type="submit" class="btn btn-med-primary px-3 py-2"><i class="fa-solid fa-magnifying-glass"></i></button>
          </form>
          <span class="text-muted small">Registered Patients</span>
        </div>

        <div class="table-responsive">
          <table class="table med-table align-middle" id="patientTable">
            <thead>
              <tr>
                <th>Patient Name</th>
                <th>Age</th>
                <th>Gender</th>
                <th>Contact</th>
                <th>Joined Date</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (patients.length === 0) { %>
                <tr>
                  <td colspan="6" class="text-center py-4 text-muted">No patients found. Match search term or register accounts.</td>
                </tr>
              <% } else { %>
                <% patients.forEach(pat => { %>
                  <tr>
                    <td class="font-weight-bold text-dark"><%= pat.name %></td>
                    <td><%= pat.age %> Yrs</td>
                    <td><%= pat.gender %></td>
                    <td>
                      <small class="d-block text-dark font-weight-bold"><%= pat.phone %></small>
                      <small class="text-muted"><%= pat.email %></small>
                    </td>
                    <td><%= new Date(pat.createdAt || Date.now()).toLocaleDateString() %></td>
                    <td>
                      <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-primary border-2 px-3 rounded-3" 
                          onclick="openEditModal('<%= pat._id %>', '<%= pat.name %>', '<%= pat.email %>', '<%= pat.age %>', '<%= pat.gender %>', '<%= pat.phone %>')">
                          <i class="fa-solid fa-edit"></i> Edit
                        </button>
                        
                        <button class="btn btn-sm btn-outline-secondary border-2 px-3 rounded-3" onclick="viewHistoryModal('<%= pat._id %>')">
                          <i class="fa-solid fa-folder-open"></i> History
                        </button>

                        <form action="/admin/patients/delete" method="POST" onsubmit="return confirm('Are you sure you want to remove this patient? This will permanently delete their portal account and cancel all active bookings.');">
                          <input type="hidden" name="patientId" value="<%= pat._id %>">
                          <button type="submit" class="btn btn-sm btn-outline-danger border-2 px-3 rounded-3">
                            <i class="fa-solid fa-trash"></i> Delete
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </main>
</div>

<!-- Modal: Edit Patient -->
<div class="modal fade" id="editPatientModal" tabindex="-1" aria-labelledby="editPatientModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
      <div class="modal-header border-bottom bg-light" style="border-radius: 20px 20px 0 0;">
        <h5 class="modal-title font-weight-bold display-font text-dark" id="editPatientModalLabel"><i class="fa-solid fa-user-edit text-primary me-2"></i> Modify Patient Information</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="/admin/patients/edit" method="POST">
        <input type="hidden" name="patientId" id="editPatId">
        <div class="modal-body p-4">
          <div class="mb-3">
            <label class="form-label text-muted small font-weight-bold">Full Name</label>
            <input type="text" name="name" id="editPatName" class="form-control form-med-control" required>
          </div>
          
          <div class="mb-3">
            <label class="form-label text-muted small font-weight-bold">Email Address</label>
            <input type="email" name="email" id="editPatEmail" class="form-control form-med-control" required>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label class="form-label text-muted small font-weight-bold">Age</label>
              <input type="number" name="age" id="editPatAge" class="form-control form-med-control" min="1" max="120" required>
            </div>
            
            <div class="col-md-6">
              <label class="form-label text-muted small font-weight-bold">Gender</label>
              <select name="gender" id="editPatGender" class="form-select form-med-control" required style="height: 50px;">
                <option value="Male">Male</option>
                <option value="Female">Female</option>
                <option value="Other">Other</option>
              </select>
            </div>
          </div>

          <div class="mb-2">
            <label class="form-label text-muted small font-weight-bold">Phone Number</label>
            <input type="tel" name="phone" id="editPatPhone" class="form-control form-med-control" required>
          </div>
        </div>
        <div class="modal-footer bg-light border-top" style="border-radius: 0 0 20px 20px;">
          <button type="button" class="btn btn-secondary px-3" data-bs-dismiss="modal" style="border-radius: 10px;">Cancel</button>
          <button type="submit" class="btn btn-med-primary px-4">Save Changes</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Modal: History Logs -->
<div class="modal fade" id="historyModal" tabindex="-1" aria-labelledby="historyModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
      <div class="modal-header border-bottom bg-light" style="border-radius: 20px 20px 0 0;">
        <h5 class="modal-title font-weight-bold display-font text-dark" id="historyModalLabel"><i class="fa-solid fa-clipboard-user text-primary me-2"></i> Patient Appointment Records</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4">
        
        <!-- Spinner Loader -->
        <div id="modalLoader" class="text-center py-5">
          <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
          <p class="text-muted mt-3 mb-0">Retrieving patient appointment logs...</p>
        </div>

        <div id="modalData" class="d-none">
          <h6 class="text-dark font-weight-bold mb-3 border-bottom pb-2">Consultation Dossier</h6>
          <div class="table-responsive" style="max-height: 300px; overflow-y: auto;">
            <table class="table align-middle text-sm">
              <thead>
                <tr class="text-muted border-bottom small">
                  <th>Doctor</th>
                  <th>Date</th>
                  <th>Time Slot</th>
                  <th>Symptoms</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody id="apptLogsTableBody">
                <!-- Loaded dynamically -->
              </tbody>
            </table>
          </div>
        </div>

      </div>
      <div class="modal-footer bg-light border-top" style="border-radius: 0 0 20px 20px;">
        <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal" style="border-radius: 10px;">Close Folder</button>
      </div>
    </div>
  </div>
</div>

<script>
  let editPatientModal = null;
  let historyModal = null;

  document.addEventListener('DOMContentLoaded', () => {
    editPatientModal = new bootstrap.Modal(document.getElementById('editPatientModal'));
    historyModal = new bootstrap.Modal(document.getElementById('historyModal'));
  });

  // Pre-fill Edit Patient
  function openEditModal(id, name, email, age, gender, phone) {
    document.getElementById('editPatId').value = id;
    document.getElementById('editPatName').value = name;
    document.getElementById('editPatEmail').value = email;
    document.getElementById('editPatAge').value = age;
    document.getElementById('editPatGender').value = gender;
    document.getElementById('editPatPhone').value = phone;
    editPatientModal.show();
  }

  // Load Patient Appointment Logs (Ajax)
  async function viewHistoryModal(patientId) {
    historyModal.show();
    
    const loader = document.getElementById('modalLoader');
    const dataPanel = document.getElementById('modalData');
    
    loader.classList.remove('d-none');
    dataPanel.classList.add('d-none');

    try {
      // Re-use the history endpoint from doctor route for convenience
      const response = await fetch(`/doctor/patient-history/${patientId}`);
      const data = await response.json();

      if (response.ok) {
        const tbody = document.getElementById('apptLogsTableBody');
        tbody.innerHTML = '';

        if (data.appointments.length === 0) {
          tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted">No appointments found.</td></tr>';
        } else {
          data.appointments.forEach(appt => {
            const badgeClass = appt.status === 'completed' ? 'bg-success-light text-success' 
                             : appt.status === 'cancelled' || appt.status === 'rejected' ? 'bg-danger-light text-danger'
                             : 'bg-warning-light text-warning';

            tbody.innerHTML += `
              <tr class="border-bottom border-light">
                <td class="font-weight-bold text-dark">${appt.doctorName}</td>
                <td>${appt.date}</td>
                <td>${appt.timeSlot}</td>
                <td class="text-muted" style="max-width: 250px;">${appt.symptoms || 'Routine checkup'}</td>
                <td><span class="badge ${badgeClass} text-uppercase font-weight-bold" style="font-size:0.7rem; border-radius:10px;">${appt.status}</span></td>
              </tr>
            `;
          });
        }

        loader.classList.add('d-none');
        dataPanel.classList.remove('d-none');
      } else {
        alert('Failed to retrieve patient logs.');
      }
    } catch (err) {
      console.error('Error fetching logs:', err);
      alert('Error fetching patient records.');
    }
  }
</script>

<%- include('../partials/footer') %>
