<%- include('partials/header') %>
<%- include('partials/navbar') %>

<!-- Hero Section -->
<section class="hero-section">
  <div class="hero-shape-1"></div>
  <div class="hero-shape-2"></div>
  <div class="container position-relative" style="z-index: 10;">
    <div class="row align-items-center min-vh-75 pt-5">
      <div class="col-lg-6 slide-up">
        <span class="badge bg-primary-light text-primary px-3 py-2 rounded-pill font-weight-bold mb-3">
          <i class="fa-solid fa-bolt me-1"></i> Next-Gen Smart Queue Management
        </span>
        <h1 class="hero-title text-gradient">Skip the Waiting Room, Not Your Care.</h1>
        <p class="lead text-muted mb-4 fs-5" style="max-width: 550px;">
          MedQueue revolutionizes hospital waiting rooms. Book verified appointments, check live queue positions in real-time, and walk in exactly when the doctor is ready for you.
        </p>
        <div class="d-flex flex-wrap gap-3">
          <% if (!user) { %>
            <a href="/login?role=patient" class="btn btn-med-primary px-4 py-3">
              <i class="fa-solid fa-calendar-check me-2"></i> Book Appointment Now
            </a>
            <a href="/register" class="btn btn-med-secondary px-4 py-3">
              <i class="fa-solid fa-user-plus me-2"></i> Patient Signup
            </a>
          <% } else { %>
            <a href="/<%= user.role %>/dashboard" class="btn btn-med-primary px-4 py-3">
              <i class="fa-solid fa-gauge me-2"></i> Go to Dashboard
            </a>
          <% } %>
        </div>
      </div>
      <div class="col-lg-6 mt-5 mt-lg-0 text-center fade-in">
        <div class="position-relative d-inline-block">
          <img src="https://images.unsplash.com/photo-1576091160550-2173dba999ef?auto=format&fit=crop&w=600&q=80" alt="Smart Hospital Dashboard" class="img-fluid rounded-4 shadow-lg border border-white border-4" style="max-width: 90%;">
          
          <!-- Floating UI Cards for Premium Look -->
          <div class="med-card position-absolute d-none d-md-flex align-items-center bg-white p-3 shadow-lg border border-light" style="bottom: 20px; left: -40px; border-radius: 16px; width: 250px;">
            <div class="med-card-icon bg-success-light text-success me-3 mb-0" style="width: 40px; height: 40px; border-radius: 10px; font-size: 1.1rem;">
              <i class="fa-solid fa-check-circle"></i>
            </div>
            <div>
              <h6 class="mb-0 text-dark font-weight-bold">Live Status</h6>
              <small class="text-success font-weight-bold"><i class="fa-solid fa-circle-play me-1"></i> Doctor is Ready</small>
            </div>
          </div>
          
          <div class="med-card position-absolute d-none d-md-flex align-items-center bg-white p-3 shadow-lg border border-light" style="top: 40px; right: -30px; border-radius: 16px; width: 220px;">
            <div class="med-card-icon bg-warning-light text-warning me-3 mb-0" style="width: 40px; height: 40px; border-radius: 10px; font-size: 1.1rem;">
              <i class="fa-solid fa-clock"></i>
            </div>
            <div>
              <h6 class="mb-0 text-dark font-weight-bold">Token T-04</h6>
              <small class="text-muted">Wait time: ~ 12 mins</small>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Stats Counters Section -->
<section class="py-5 bg-white border-bottom border-top">
  <div class="container">
    <div class="row text-center">
      <div class="col-6 col-lg-3">
        <div class="counter-box">
          <div class="counter-number">15k+</div>
          <p class="text-muted font-weight-bold mb-0">Patients Served</p>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="counter-box">
          <div class="counter-number">50+</div>
          <p class="text-muted font-weight-bold mb-0">Top Specialists</p>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="counter-box">
          <div class="counter-number"><5 min</div>
          <p class="text-muted font-weight-bold mb-0">Avg. Waiting Time</p>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="counter-box">
          <div class="counter-number">99.8%</div>
          <p class="text-muted font-weight-bold mb-0">On-Time Reviews</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Services / Offerings -->
<section id="services" class="py-5 section-offset" style="background: #f8fafc;">
  <div class="container py-4">
    <div class="text-center mb-5">
      <span class="text-primary font-weight-bold text-uppercase letter-spacing-1">Premium Services</span>
      <h2 class="h1 display-font text-dark mt-2 mb-3">Redefining Patient Journeys</h2>
      <p class="text-muted mx-auto" style="max-width: 600px;">Our workflow replaces long lines with digital transparency, empowering patients and optimize doctor scheduling.</p>
    </div>
    
    <div class="row g-4">
      <div class="col-md-4">
        <div class="med-card h-100">
          <div class="med-card-icon">
            <i class="fa-solid fa-calendar-days"></i>
          </div>
          <h4 class="mb-3">OPD Slot Booking</h4>
          <p class="text-muted">Select departments, review real-time availability calendar, choose timeslots, and secure bookings in under 60 seconds.</p>
        </div>
      </div>
      
      <div class="col-md-4">
        <div class="med-card h-100">
          <div class="med-card-icon" style="background: var(--secondary-light); color: var(--secondary);">
            <i class="fa-solid fa-qrcode"></i>
          </div>
          <h4 class="mb-3">Live Digital Tokens</h4>
          <p class="text-muted">Generate instant digital tokens. No printouts needed—your live dashboard displays queue status and estimated wait times on the fly.</p>
        </div>
      </div>
      
      <div class="col-md-4">
        <div class="med-card h-100">
          <div class="med-card-icon" style="background: var(--success-light); color: var(--success);">
            <i class="fa-solid fa-triangle-exclamation"></i>
          </div>
          <h4 class="mb-3">Emergency Priority</h4>
          <p class="text-muted">Critical emergency patients are elevated to the front of the queue by staff. Wait times for subsequent patients adjust instantly.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Why Choose Us / Detailed Feature Grid -->
<section id="features" class="py-5 bg-white">
  <div class="container py-4">
    <div class="row align-items-center">
      <div class="col-lg-5 mb-5 mb-lg-0">
        <span class="text-primary font-weight-bold text-uppercase">The MedQueue Advantage</span>
        <h2 class="h1 display-font mt-2 mb-4">Why Hospitals Choose MedQueue</h2>
        <p class="text-muted mb-4">
          Typical hospital queue systems rely on static booking sheets or paper numbers. MedQueue utilizes active websockets to synchronize queues across devices instantly, preventing crowded lobbies and improving hospital reputation.
        </p>
        <ul class="list-unstyled">
          <li class="d-flex align-items-center mb-3">
            <i class="fa-solid fa-circle-check text-success me-3 fs-5"></i>
            <strong class="text-dark">Socket.IO real-time updates</strong>
          </li>
          <li class="d-flex align-items-center mb-3">
            <i class="fa-solid fa-circle-check text-success me-3 fs-5"></i>
            <strong class="text-dark">Flexible doctor schedule planners</strong>
          </li>
          <li class="d-flex align-items-center mb-3">
            <i class="fa-solid fa-circle-check text-success me-3 fs-5"></i>
            <strong class="text-dark">Admin dashboard analytics (Chart.js)</strong>
          </li>
          <li class="d-flex align-items-center">
            <i class="fa-solid fa-circle-check text-success me-3 fs-5"></i>
            <strong class="text-dark">Fully responsive Bootstrap 5 interface</strong>
          </li>
        </ul>
      </div>
      <div class="col-lg-7">
        <div class="row g-4 ps-lg-5">
          <div class="col-sm-6">
            <div class="med-card">
              <h5 class="text-dark font-weight-bold mb-2"><i class="fa-solid fa-user-shield text-primary me-2"></i> Role Dashboards</h5>
              <p class="text-muted mb-0 small">Specialized interfaces for Patient booking, Doctor queue calling, and Admin operations management.</p>
            </div>
          </div>
          <div class="col-sm-6">
            <div class="med-card">
              <h5 class="text-dark font-weight-bold mb-2"><i class="fa-solid fa-gauge-high text-primary me-2"></i> Wait Estimations</h5>
              <p class="text-muted mb-0 small">Smart algorithm recalculates wait times dynamically based on average duration, completed reviews, and break schedules.</p>
            </div>
          </div>
          <div class="col-sm-6">
            <div class="med-card">
              <h5 class="text-dark font-weight-bold mb-2"><i class="fa-solid fa-chart-line text-primary me-2"></i> Advanced Metrics</h5>
              <p class="text-muted mb-0 small">Admin panel displays queue lengths, patient volumes, daily trends, and doctor workloads using interactive charts.</p>
            </div>
          </div>
          <div class="col-sm-6">
            <div class="med-card">
              <h5 class="text-dark font-weight-bold mb-2"><i class="fa-solid fa-handshake-angle text-primary me-2"></i> Doctor Autonomy</h5>
              <p class="text-muted mb-0 small">Doctors can accept or reject bookings with reasons, schedule breaks, skip absent patients, or call next with one tap.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Departments Section -->
<section id="departments" class="py-5" style="background: #f8fafc;">
  <div class="container py-4">
    <div class="text-center mb-5">
      <span class="text-primary font-weight-bold text-uppercase">Specialties</span>
      <h2 class="h1 display-font text-dark mt-2 mb-3">Our Clinical Departments</h2>
      <p class="text-muted mx-auto" style="max-width: 600px;">Direct access to experienced healthcare professionals across diverse fields of medicine.</p>
    </div>
    
    <div class="row g-4 justify-content-center">
      <% departments.forEach(dept => { %>
        <div class="col-md-4 col-sm-6">
          <div class="med-card text-center h-100 d-flex flex-column align-items-center">
            <div class="med-card-icon mx-auto">
              <i class="fa-solid <%= dept.icon || 'fa-user-md' %>"></i>
            </div>
            <h4 class="mb-2"><%= dept.name %></h4>
            <p class="text-muted mb-0 small"><%= dept.description %></p>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

