<!-- FAQ Section -->
<section id="faq" class="py-5" style="background: #f8fafc;">
  <div class="container py-4">
    <div class="text-center mb-5">
      <span class="text-primary font-weight-bold text-uppercase">FAQ</span>
      <h2 class="h1 display-font text-dark mt-2 mb-3">Frequently Asked Questions</h2>
    </div>
    
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="accordion accordion-flush bg-white rounded-4 shadow-sm p-3" id="accordionFAQ">
          
          <div class="accordion-item border-0 border-bottom">
            <h2 class="accordion-header" id="headingOne">
              <button class="accordion-button collapsed font-weight-bold py-3 text-dark" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="false" aria-controls="collapseOne">
                How does the real-time queue position update work?
              </button>
            </h2>
            <div id="collapseOne" class="accordion-collapse collapse" aria-labelledby="headingOne" data-bs-parent="#accordionFAQ">
              <div class="accordion-body text-muted">
                Our application integrates Socket.IO websockets. As soon as the doctor calls the next token, skipped tokens, or complete consultations, an event is emitted from the backend and immediately updates your queue position and waiting time estimation on your device without needing a page refresh.
              </div>
            </div>
          </div>
          
          <div class="accordion-item border-0 border-bottom">
            <h2 class="accordion-header" id="headingTwo">
              <button class="accordion-button collapsed font-weight-bold py-3 text-dark" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                How are the waiting times estimated?
              </button>
            </h2>
            <div id="collapseTwo" class="accordion-collapse collapse" aria-labelledby="headingTwo" data-bs-parent="#accordionFAQ">
              <div class="accordion-body text-muted">
                Waiting times are calculated by multiplying the number of people ahead of you in the active queue list by the doctor's average consultation duration (e.g. 15 mins). If a doctor pauses the queue for a scheduled break, the system flags the delay on your dashboard.
              </div>
            </div>
          </div>

          <div class="accordion-item border-0">
            <h2 class="accordion-header" id="headingThree">
              <button class="accordion-button collapsed font-weight-bold py-3 text-dark" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree" aria-expanded="false" aria-controls="collapseThree">
                Can I reschedule or cancel my appointment?
              </button>
            </h2>
            <div id="collapseThree" class="accordion-collapse collapse" aria-labelledby="headingThree" data-bs-parent="#accordionFAQ">
              <div class="accordion-body text-muted">
                Yes! From the "My Appointments" panel in your patient portal, you can cancel any upcoming booking instantly. The backend will remove you from the queue state automatically, reducing the wait time for all subsequent patients.
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<!-- Contact Section -->
<section id="contact" class="py-5 bg-white">
  <div class="container py-4">
    <div class="text-center mb-5">
      <span class="text-primary font-weight-bold text-uppercase">Contact</span>
      <h2 class="h1 display-font text-dark mt-2 mb-3">Get in Touch</h2>
    </div>
    
    <div class="row align-items-stretch g-4">
      <div class="col-lg-5">
        <div class="med-card bg-primary text-white h-100 p-5 d-flex flex-column justify-content-between" style="border: none;">
          <div>
            <h3 class="text-white mb-4 display-font">Emergency Support</h3>
            <p class="text-white-50">Our hospital care coordinators are available 24/7 to assist with queue management inquiries, scheduling, or technical support.</p>
            
            <div class="mt-4">
              <div class="d-flex align-items-center mb-3">
                <i class="fa-solid fa-phone me-3 text-white fs-5"></i>
                <span>+1 (800) MED-QUEUE</span>
              </div>
              <div class="d-flex align-items-center mb-3">
                <i class="fa-solid fa-envelope me-3 text-white fs-5"></i>
                <span>support@medqueue.com</span>
              </div>
              <div class="d-flex align-items-center">
                <i class="fa-solid fa-location-dot me-3 text-white fs-5"></i>
                <span>100 Health Sciences Pkwy, Suite 400</span>
              </div>
            </div>
          </div>
          
          <div class="mt-5 text-white-50 small border-top pt-3 border-white-10">
            © 2026 MedQueue Inc. All rights reserved.
          </div>
        </div>
      </div>
      
      <div class="col-lg-7">
        <div class="med-card h-100 p-5">
          <h3 class="text-dark mb-4 display-font">Send a Message</h3>
          <form>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label text-muted small font-weight-bold">Your Name</label>
                <input type="text" class="form-control form-med-control" placeholder="John Doe" required>
              </div>
              <div class="col-md-6">
                <label class="form-label text-muted small font-weight-bold">Email Address</label>
                <input type="email" class="form-control form-med-control" placeholder="john@example.com" required>
              </div>
              <div class="col-12">
                <label class="form-label text-muted small font-weight-bold">Subject</label>
                <input type="text" class="form-control form-med-control" placeholder="Hospital Queue Setup Inquiry" required>
              </div>
              <div class="col-12">
                <label class="form-label text-muted small font-weight-bold">Message</label>
                <textarea class="form-control form-med-control" rows="4" placeholder="How can we help you?" required></textarea>
              </div>
              <div class="col-12">
                <button type="submit" class="btn btn-med-primary px-4 py-3 w-100">Send Message</button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="py-4 border-top bg-light">
  <div class="container text-center">
    <div class="d-flex justify-content-center align-items-center mb-3">
      <a class="navbar-brand text-gradient d-flex align-items-center font-weight-bold" href="#">
        <i class="fa-solid fa-hospital-user me-2 text-primary"></i>
        <span>MedQueue</span>
      </a>
    </div>
    <p class="text-muted small mb-0">Designed & engineered as a high-fidelity healthcare project. Built using Express, MongoDB and Socket.IO.</p>
  </div>
</footer>

